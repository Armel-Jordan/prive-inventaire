<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE"/>

    <application
        android:name=".PriseApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_logo_prise"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_logo_prise"
        android:supportsRtl="true"
        android:theme="@style/Theme.PriseInventaire"
        tools:targetApi="31">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.PriseInventaire">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ActivityMain"
            android:exported="false"
            android:theme="@style/Theme.PriseInventaire"/>
        <activity
            android:name=".EmployeLoginActivity"
            android:exported="false"
            android:theme="@style/Theme.PriseInventaire"/>
        <activity
            android:name=".SecteurActivity"
            android:exported="false"
            android:theme="@style/Theme.PriseInventaire"/>
        <activity
            android:name=".InventaireScanActivity"
            android:exported="false"
            android:theme="@style/Theme.PriseInventaire"/>
        <activity
            android:name=".ConfigActivity"
            android:exported="false"/>
        <activity
            android:name=".HistoriqueActivity"
            android:exported="false"
            android:theme="@style/Theme.PriseInventaire"/>
        <activity
            android:name=".RelocalisationActivity"
            android:exported="false"
            android:theme="@style/Theme.PriseInventaire"/>
        <activity
            android:name=".HistoriqueLocalActivity"
            android:exported="false"
            android:theme="@style/Theme.PriseInventaire"/>
    </application>

</manifest>
