option_settings:
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    memory_limit: 256M
    max_execution_time: 60
    composer_options: --no-dev --optimize-autoloader --no-scripts

container_commands:
  01_create_env:
    command: |
      echo "APP_NAME=\"Prise Inventaire\"" > .env
      echo "APP_ENV=production" >> .env
      echo "APP_DEBUG=false" >> .env
      echo "APP_URL=http://prise-api-prod.eba-ghrnc2uz.us-east-1.elasticbeanstalk.com" >> .env
      echo "APP_KEY=base64:vKZEoll7zwkbuJKZ/wLrg3VxRT1HOhds1YeLlIHdkYA=" >> .env
      echo "DB_CONNECTION=mysql" >> .env
      echo "DB_HOST=prise-inventaire.c2dai848u8x4.us-east-1.rds.amazonaws.com" >> .env
      echo "DB_PORT=3306" >> .env
      echo "DB_DATABASE=prise_central" >> .env
      echo "DB_USERNAME=admin" >> .env
      echo "DB_PASSWORD=PriseInv2026!" >> .env
      echo "LOG_CHANNEL=stderr" >> .env
  02_fix_permissions:
    command: "mkdir -p storage/framework/sessions storage/framework/views storage/framework/cache storage/logs bootstrap/cache && chmod -R 777 storage bootstrap/cache && chmod 644 .env || true"
  03_clear_cache:
    command: "php artisan config:clear && php artisan cache:clear || true"
  04_migrate:
    command: "php artisan migrate --force || true"
    leader_only: true
  05_storage_link:
    command: "php artisan storage:link || true"
    leader_only: true
