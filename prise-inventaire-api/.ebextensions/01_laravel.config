option_settings:
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    memory_limit: 256M
    max_execution_time: 60
    composer_options: --no-dev --optimize-autoloader

container_commands:
  01_fix_permissions:
    command: "chmod -R 777 storage bootstrap/cache || true"
  02_migrate:
    command: "php artisan migrate --force || true"
    leader_only: true
  03_storage_link:
    command: "php artisan storage:link || true"
    leader_only: true
