option_settings:
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    memory_limit: 256M
    max_execution_time: 60
  aws:elasticbeanstalk:application:environment:
    APP_ENV: production
    APP_DEBUG: false
    LOG_CHANNEL: stderr

container_commands:
  01_install_composer:
    command: "export COMPOSER_HOME=/root && /usr/bin/composer.phar install --no-dev --optimize-autoloader"
    leader_only: true
  02_generate_key:
    command: "php artisan key:generate --force"
    leader_only: true
  03_cache_config:
    command: "php artisan config:cache"
    leader_only: true
  04_cache_routes:
    command: "php artisan route:cache"
    leader_only: true
  05_cache_views:
    command: "php artisan view:cache"
    leader_only: true
  06_run_migrations:
    command: "php artisan migrate --force"
    leader_only: true
